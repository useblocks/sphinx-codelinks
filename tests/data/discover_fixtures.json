[
  {
    "name": "basic_cpp_no_gitignore",
    "description": "Discover C++ files by extension with gitignore disabled",
    "git_init": false,
    "files": {
      "src/main.cpp": "// main",
      "src/util.h": "// header",
      "src/readme.txt": "not source"
    },
    "config": {
      "src_dir": "src",
      "include": [],
      "exclude": [],
      "gitignore": false,
      "comment_type": "cpp"
    },
    "expected": [
      "src/main.cpp",
      "src/util.h"
    ]
  },
  {
    "name": "gitignore_excludes_directory",
    "description": "Gitignore excludes an entire directory",
    "git_init": true,
    "files": {
      "src/main.cpp": "// main",
      "src/util.cpp": "// util",
      "src/build/generated.cpp": "// generated",
      "src/.gitignore": "build/\n"
    },
    "config": {
      "src_dir": "src",
      "include": [],
      "exclude": [],
      "gitignore": true,
      "comment_type": "cpp"
    },
    "expected": [
      "src/main.cpp",
      "src/util.cpp"
    ]
  },
  {
    "name": "nested_gitignore",
    "description": "Nested .gitignore excludes a specific pattern in a subdirectory",
    "git_init": true,
    "files": {
      "src/main.cpp": "// main",
      "src/vendor/lib.cpp": "// vendor lib",
      "src/vendor/lib.generated.cpp": "// generated",
      "src/vendor/.gitignore": "*.generated.cpp\n"
    },
    "config": {
      "src_dir": "src",
      "include": [],
      "exclude": [],
      "gitignore": true,
      "comment_type": "cpp"
    },
    "expected": [
      "src/main.cpp",
      "src/vendor/lib.cpp"
    ]
  },
  {
    "name": "explicit_exclude_pattern",
    "description": "Exclude patterns filter out matching files",
    "git_init": false,
    "files": {
      "src/main.cpp": "// code",
      "src/build/generated.cpp": "// generated"
    },
    "config": {
      "src_dir": "src",
      "include": [],
      "exclude": ["**/build/**"],
      "gitignore": false,
      "comment_type": "cpp"
    },
    "expected": [
      "src/main.cpp"
    ]
  },
  {
    "name": "explicit_include_pattern",
    "description": "Include patterns restrict discovery to matching files only",
    "git_init": false,
    "files": {
      "src/main.cpp": "// main",
      "src/util.h": "// header",
      "src/readme.txt": "not source"
    },
    "config": {
      "src_dir": "src",
      "include": ["**/*.cpp"],
      "exclude": [],
      "gitignore": false,
      "comment_type": "cpp"
    },
    "expected": [
      "src/main.cpp"
    ]
  },
  {
    "name": "include_and_exclude_combined",
    "description": "Include and exclude patterns work together",
    "git_init": false,
    "files": {
      "src/main.cpp": "// main",
      "src/test_main.cpp": "// test",
      "src/lib/util.cpp": "// util",
      "src/lib/test_util.cpp": "// test util"
    },
    "config": {
      "src_dir": "src",
      "include": ["**/*.cpp"],
      "exclude": ["**/test_*.cpp"],
      "gitignore": false,
      "comment_type": "cpp"
    },
    "expected": [
      "src/lib/util.cpp",
      "src/main.cpp"
    ]
  },
  {
    "name": "default_include_from_language",
    "description": "When include is empty, files are discovered by language extensions",
    "git_init": false,
    "files": {
      "src/main.cpp": "// code",
      "src/util.h": "// header",
      "src/helper.hpp": "// hpp header",
      "src/readme.txt": "not source",
      "src/data.json": "not source"
    },
    "config": {
      "src_dir": "src",
      "include": [],
      "exclude": [],
      "gitignore": false,
      "comment_type": "cpp"
    },
    "expected": [
      "src/helper.hpp",
      "src/main.cpp",
      "src/util.h"
    ]
  },
  {
    "name": "hidden_files_discovered",
    "description": "Hidden files (dotfiles) are discovered since hidden(false) is set",
    "git_init": false,
    "files": {
      "src/main.cpp": "// main",
      "src/.hidden.cpp": "// hidden"
    },
    "config": {
      "src_dir": "src",
      "include": [],
      "exclude": [],
      "gitignore": false,
      "comment_type": "cpp"
    },
    "expected": [
      "src/.hidden.cpp",
      "src/main.cpp"
    ]
  },
  {
